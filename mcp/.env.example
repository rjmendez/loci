# === hermes-memory MCP server — environment configuration ===
# Copy to .env and fill in values. .env is gitignored.
# The top-level .env.example covers all variables including these.
# This file exists for deployments that run only the MCP server.

# ── Qdrant (required) ────────────────────────────────────────
QDRANT_URL=
QDRANT_API_KEY=

# ── Ollama embeddings (required — 768-dim) ───────────────────
OLLAMA_BASE_URL=
MNEMOSYNE_EMBEDDING_API_URL=
MNEMOSYNE_EMBEDDING_MODEL=nomic-embed-text
MNEMOSYNE_EMBEDDING_DIM=768

# ── Optional extra collections ───────────────────────────────
# Collection of code-chunk embeddings for code_memory_correlate
CODE_CHUNKS_COLLECTION=

# Collection of routing/decision records for routing query tool
ROUTING_DECISIONS_COLLECTION=

# ── MCP transport (for Docker / remote access) ───────────────
# Set to "sse" or "streamable-http" when running in a container.
# Leave unset (defaults to "stdio") for Claude Code subprocess mode.
# HERMES_MCP_TRANSPORT=sse
# HERMES_MCP_HOST=0.0.0.0
# HERMES_MCP_PORT=8000

# ── Mnemosyne (optional) ─────────────────────────────────────
# Leave unset to run in Qdrant-only mode.
# HERMES_MNEMO_BANK=default
# MNEMOSYNE_DATA_DIR=~/.hermes/mnemosyne/data

# ── fastembed fallback (optional) ────────────────────────────
# CPU-only 384-dim fallback when Ollama is unavailable.
# Vectors differ from nomic → requires separate Qdrant collections.
# FASTEMBED_MODEL=BAAI/bge-small-en-v1.5
