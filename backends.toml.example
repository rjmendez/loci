# Loci backend config — copy to ~/.loci/backends.toml (or point $LOCI_CONFIG at it) and edit.
# This file holds MACHINE-SPECIFIC endpoints/keys so they never live in the public repo.
# Resolution order per backend: env var > local probe (localhost) > this file > safe default.
# So on a laptop with its own Ollama you can leave everything blank (the probe finds it);
# on a headless box, point these at a GPU host reachable over your network (LAN, VPN/tailscale).
# The hosts below are PLACEHOLDERS — replace with your own.

[ollama]
# url = "http://gpu-host:11434"        # remote Ollama / local GPU host (omit to use local :11434)

[embed]
# model = "nomic-embed-text"

[vllm]
# url = "http://gpu-host:8000"         # batched OpenAI-compatible server (omit -> Ollama fallback)
# model = "Qwen/Qwen2.5-3B-Instruct"

[rerank]
# model = "BAAI/bge-reranker-v2-m3"    # default; or the lighter "cross-encoder/ms-marco-MiniLM-L-6-v2"

[qdrant]
# url = "http://qdrant-host:6333"
# api_key = "..."

[memory]
# dir = "/absolute/path/to/curated/MEMORY.md/dir"
