# ============================================================
# hermes_memory — environment variable template
# Copy to .env and fill in your values. .env is gitignored.
# ============================================================

# ── Qdrant (required) ────────────────────────────────────────
# URL of your Qdrant vector store
QDRANT_URL=

# API key for Qdrant. Leave empty if your instance has no auth.
QDRANT_API_KEY=

# ── Ollama / Embeddings (required) ──────────────────────────
# Base URL of your Ollama instance (no trailing slash, no /v1 suffix)
# Used by: mcp/server.py, a2a_server/server.py, hook scripts (pre_llm_grounding.py, session_end_sync.py)
OLLAMA_BASE_URL=

# Same URL — used by standalone consolidation scripts (amem_consolidation.py,
# agentHER_relabeler.py, memgas_hierarchy.py, ebbinghaus_consolidation.py,
# exif_skill_discovery.py, score_trace_collector.py, skillops_maintenance.py).
# Note: OLLAMA_URL and OLLAMA_BASE_URL serve different components — set both.
OLLAMA_URL=

# OpenAI-compat embedding API used by Mnemosyne sync scripts
# (typically OLLAMA_BASE_URL + /v1)
MNEMOSYNE_EMBEDDING_API_URL=

# Embedding model — must produce 768-dim vectors to match default collections.
# Ollama default: nomic-embed-text (`ollama pull nomic-embed-text`)
# Azure OpenAI:   text-embedding-3-small  (set EMBED_API_KEY + EMBED_API_KEY_HEADER=api-key)
# OpenAI direct:  text-embedding-3-small  (set EMBED_API_KEY; header defaults to Authorization)
# AWS Bedrock:    amazon.titan-embed-text-v2:0  (use Bedrock OpenAI-compat endpoint)
MNEMOSYNE_EMBEDDING_MODEL=nomic-embed-text
MNEMOSYNE_EMBEDDING_DIM=768

# Cloud embedding auth (leave blank for Ollama; no auth needed for local)
# Set EMBED_API_KEY to your provider's API key.
# EMBED_API_KEY_HEADER defaults to "Authorization" (Bearer <key>) — OpenAI/Bedrock style.
# Set EMBED_API_KEY_HEADER=api-key for Azure OpenAI (key passed as header value directly).
EMBED_API_KEY=
EMBED_API_KEY_HEADER=Authorization

# ── Agent identity ───────────────────────────────────────────
# Unique name for this agent node. Stamped on every memory write.
HERMES_AGENT_ID=my-agent
MNEMOSYNE_AUTHOR_ID=my-agent
MNEMOSYNE_AUTHOR_TYPE=agent

# Optional namespace tag stamped on all Qdrant memory writes.
# Use this to partition a shared Qdrant instance by team or project.
# Leave blank for single-tenant deployments.
# LOCI_NAMESPACE=

# Path to the .env file loaded at startup by the A2A server and sync scripts.
# Defaults to ~/.hermes/.env — set this if you store your env elsewhere.
# HERMES_ENV_FILE=~/.hermes/.env

# ── A2A server auth ──────────────────────────────────────────
# Bearer token callers must present. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
HERMES_A2A_TOKEN=

# Optional TOTP seed (base32 string). Leave blank to disable TOTP.
HERMES_A2A_TOTP_SEED=

# Public URL this server listens on (injected into the A2A agent card)
HERMES_A2A_URL=http://127.0.0.1:8201

# Bind address and port (defaults: 0.0.0.0 and 8201)
# HERMES_A2A_HOST=0.0.0.0
# HERMES_A2A_PORT=8201

# ── Peer A2A endpoints (optional) ───────────────────────────
# Comma-separated list of peer /a2a endpoints for context broadcast.
# Leave empty for single-node deployments.
PEER_A2A_URLS=
# Shared bearer token for all peers (overridden per-peer by PEER_A2A_TOKENS_JSON)
PEER_A2A_TOKEN=
# Per-peer token overrides (JSON map of base-URL → token)
# PEER_A2A_TOKENS_JSON={"http://peer-a:8201": "token-a"}

# ── Extra RAG collections (optional) ────────────────────────
# Comma-separated Qdrant collection names to include in fan-out RAG search
# and the pre-LLM grounding hook. Leave empty to use only the built-in
# hermes_memory, hermes_sessions, and mnemosyne collections.
#
# Example: EXTRA_RAG_COLLECTIONS=my_codebase,my_docs
EXTRA_RAG_COLLECTIONS=

# Same setting scoped to the grounding hook only (defaults to EXTRA_RAG_COLLECTIONS
# if not set independently).
GROUNDING_EXTRA_COLLECTIONS=

# ── Domain-specific tool collections (optional) ──────────────
# Set these only if you have the matching Qdrant collections.
# If unset the corresponding tool/skill returns a "not configured" error
# rather than failing silently.

# Collection of code-chunk embeddings for code_memory_correlate MCP tool
CODE_CHUNKS_COLLECTION=

# Collection of routing/decision records for the routing query tool
ROUTING_DECISIONS_COLLECTION=

# Collection for the dama_telemetry A2A skill
DAMA_TELEMETRY_COLLECTION=

# ── Grounding hook tuning (optional) ────────────────────────
HOOK_RECALL_TOP_K=5
HOOK_RECALL_MIN_IMPORTANCE=0.2
HOOK_RECALL_MIN_SCORE=0.55
HOOK_RECALL_MIN_PROMPT=15
HOOK_RECALL_MAX_CHARS=200
HOOK_RULES_MAX_CHARS=1200
HOOK_EMBED_TIMEOUT=3.0
HOOK_QDRANT_TIMEOUT=2.0
HOOK_QDRANT_WORKERS=8

# Override the full grounding directive injected into every LLM turn.
# Leave blank to use the built-in generic directive.
# GROUNDING_DIRECTIVE=

# ── Pre-tool guard (optional) ────────────────────────────────
# Set to 1 to hard-block tool calls flagged by the rules engine.
# 0 (default) = soft-warn mode.
HOOK_BLOCK_MODE=0

# ── SWR replay cron (optional) ──────────────────────────────
SWR_LOOKBACK_HOURS=6
SWR_REPLAY_K=7
SWR_LLM_MODEL=llama3.2:latest

# ── Glymphatic sweep cron (optional) ────────────────────────
GLYMPHATIC_ORPHAN_TTL_DAYS=7
GLYMPHATIC_DUP_COS_THRESH=0.98

# ── Context bridge cron (optional) ──────────────────────────
BRIDGE_LOOKBACK_MIN=30
BRIDGE_MIN_IMP=0.5
BRIDGE_MAX_ITEMS=20

# ── Embedding worker (optional, for sync scripts) ────────────
# URL of a dedicated embedding worker service. Only needed if you
# run mnemosyne_qdrant_sync.py or state_db_qdrant_sync.py.
EMBED_WORKER_URL=

# ── Mnemosyne SQLite path (optional) ────────────────────────
MNEMOSYNE_DATA_DIR=~/.hermes/mnemosyne/data
